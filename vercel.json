{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/.*",
      "dest": "index.html"
    }
  ],
  "env": {
    "GOOGLE_SHEETS_ID": "@google_sheets_id",
    "GOOGLE_CREDENTIALS": "@google_credentials"
  }
}
